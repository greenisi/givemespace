{
  "manifest_version": 3,
  "name": "GiveMeSpace Companion",
  "short_name": "GiveMeSpace",
  "version": "0.1.0",
  "description": "Lets the GiveMeSpace web app drive your active browser tab — navigate, read, click, type, screenshot. Pro alternative to the desktop app.",
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "GiveMeSpace Companion",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://givemespace.ai/*",
        "https://*.givemespace.ai/*",
        "http://127.0.0.1:3000/*",
        "http://localhost:3000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
